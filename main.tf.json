{
  "provider": {
    "proxmox": {
      "endpoint": "${var.proxmox_api_url}",
      "insecure": true,
      "password": "${var.proxmox_password}",
      "username": "${var.proxmox_username}"
    }
  },
  "resource": {
    "proxmox_download_file": {
      "influxdb_template": {
        "content_type": "vztmpl",
        "datastore_id": "hd4000",
        "file_name": "influxdb-v2.7.12.tar.xz",
        "node_name": "donnager",
        "overwrite": false,
        "url": "https://github.com/jagadam97/nixos-vm-builder/releases/download/influxdb-v2.7.12/influxdb-v2.7.12.tar.xz"
      },
      "maintainarr_template": {
        "content_type": "vztmpl",
        "datastore_id": "hd4000",
        "file_name": "maintainarr-v1.5.6-6.2.1.10461-4.0.17.2952-2.4.0.5397.tar.xz",
        "node_name": "donnager",
        "overwrite": false,
        "url": "https://github.com/jagadam97/nixos-vm-builder/releases/download/maintainarr-v1.5.6-6.2.1.10461-4.0.17.2952-2.4.0.5397/maintainarr-v1.5.6-6.2.1.10461-4.0.17.2952-2.4.0.5397.tar.xz"
      },
      "postgres_template": {
        "content_type": "vztmpl",
        "datastore_id": "hd4000",
        "file_name": "postgres-v18.4.tar.xz",
        "node_name": "donnager",
        "overwrite": false,
        "url": "https://github.com/jagadam97/nixos-vm-builder/releases/download/postgres-v18.4/postgres-v18.4.tar.xz"
      },
      "qbittorrent_template": {
        "content_type": "vztmpl",
        "datastore_id": "bx500",
        "file_name": "qbittorrent-v5.2.1.tar.xz",
        "node_name": "donnager",
        "overwrite": false,
        "url": "https://github.com/jagadam97/nixos-vm-builder/releases/download/qbittorrent-v5.2.1/qbittorrent-v5.2.1.tar.xz"
      }
    },
    "proxmox_virtual_environment_container": {
      "influxdb": {
        "cpu": {
          "cores": 1
        },
        "device_passthrough": [],
        "disk": {
          "datastore_id": "local-lvm",
          "size": 4
        },
        "features": {
          "nesting": true
        },
        "initialization": {
          "dns": {
            "servers": [
              "152.70.69.235",
              "1.1.1.1",
              "8.8.8.8"
            ]
          },
          "hostname": "influxdb",
          "ip_config": [
            {
              "ipv4": {
                "address": "192.168.4.248/24",
                "gateway": "192.168.4.1"
              }
            }
          ]
        },
        "memory": {
          "dedicated": 768
        },
        "mount_point": [
          {
            "path": "/var/lib/influxdb2",
            "volume": "/mnt/pve/bx500/influxdb/data"
          },
          {
            "path": "/etc/influxdb2",
            "volume": "/mnt/pve/bx500/influxdb/config"
          }
        ],
        "network_interface": {
          "bridge": "vmbr0",
          "enabled": true,
          "name": "eth0"
        },
        "node_name": "donnager",
        "operating_system": {
          "template_file_id": "${proxmox_download_file.influxdb_template.id}",
          "type": "nixos"
        },
        "start_on_boot": true,
        "started": true,
        "tags": [
          "influxdb",
          "monitoring",
          "database"
        ],
        "unprivileged": true,
        "vm_id": 204
      },
      "maintainarr": {
        "cpu": {
          "cores": 2
        },
        "device_passthrough": [],
        "disk": {
          "datastore_id": "local-lvm",
          "size": 8
        },
        "features": {
          "nesting": true
        },
        "initialization": {
          "dns": {
            "servers": [
              "152.70.69.235",
              "1.1.1.1",
              "8.8.8.8"
            ]
          },
          "hostname": "maintainarr",
          "ip_config": [
            {
              "ipv4": {
                "address": "192.168.4.211/24",
                "gateway": "192.168.4.1"
              }
            }
          ]
        },
        "memory": {
          "dedicated": 1230
        },
        "mount_point": [
          {
            "path": "/config",
            "volume": "/mnt/pve/bx500/maintainarr"
          },
          {
            "path": "/mnt/ssd",
            "volume": "/mnt/pve/bx1000"
          },
          {
            "path": "/mnt/hdd",
            "volume": "/mnt/pve/hd4000"
          }
        ],
        "network_interface": {
          "bridge": "vmbr0",
          "enabled": true,
          "name": "eth0"
        },
        "node_name": "donnager",
        "operating_system": {
          "template_file_id": "${proxmox_download_file.maintainarr_template.id}",
          "type": "nixos"
        },
        "start_on_boot": true,
        "started": true,
        "tags": [
          "maintainarr",
          "bazarr",
          "radarr",
          "sonarr",
          "media",
          "arr"
        ],
        "unprivileged": true,
        "vm_id": 201
      },
      "postgres": {
        "cpu": {
          "cores": 2
        },
        "device_passthrough": [],
        "disk": {
          "datastore_id": "local-lvm",
          "size": 8
        },
        "features": {
          "nesting": true
        },
        "initialization": {
          "dns": {
            "servers": [
              "152.70.69.235",
              "1.1.1.1",
              "8.8.8.8"
            ]
          },
          "hostname": "postgres",
          "ip_config": [
            {
              "ipv4": {
                "address": "192.168.4.218/24",
                "gateway": "192.168.4.1"
              }
            }
          ]
        },
        "memory": {
          "dedicated": 1024
        },
        "mount_point": [
          {
            "path": "/var/lib/postgresql",
            "volume": "/mnt/pve/bx500/postgres/data"
          }
        ],
        "network_interface": {
          "bridge": "vmbr0",
          "enabled": true,
          "name": "eth0"
        },
        "node_name": "donnager",
        "operating_system": {
          "template_file_id": "${proxmox_download_file.postgres_template.id}",
          "type": "nixos"
        },
        "start_on_boot": true,
        "started": true,
        "tags": [
          "postgres",
          "timescaledb",
          "database",
          "riglab"
        ],
        "unprivileged": true,
        "vm_id": 205
      },
      "qbittorrent": {
        "cpu": {
          "cores": 2
        },
        "device_passthrough": [],
        "disk": {
          "datastore_id": "local-lvm",
          "size": 8
        },
        "features": {
          "nesting": true
        },
        "initialization": {
          "dns": {
            "servers": [
              "152.70.69.235",
              "1.1.1.1",
              "8.8.8.8"
            ]
          },
          "hostname": "qbittorrent",
          "ip_config": [
            {
              "ipv4": {
                "address": "192.168.4.212/24",
                "gateway": "192.168.4.1"
              }
            }
          ]
        },
        "memory": {
          "dedicated": 1536
        },
        "mount_point": [
          {
            "path": "/var/lib/qbittorrent",
            "volume": "/mnt/pve/bx500/qbittorrent"
          },
          {
            "path": "/mnt/ssd/downloads",
            "volume": "/mnt/pve/bx1000/downloads"
          },
          {
            "path": "/mnt/hdd/downloads",
            "volume": "/mnt/pve/hd4000/downloads"
          }
        ],
        "network_interface": {
          "bridge": "vmbr0",
          "enabled": true,
          "name": "eth0"
        },
        "node_name": "donnager",
        "operating_system": {
          "template_file_id": "${proxmox_download_file.qbittorrent_template.id}",
          "type": "nixos"
        },
        "start_on_boot": true,
        "started": true,
        "tags": [
          "qbittorrent",
          "downloads",
          "media"
        ],
        "unprivileged": true,
        "vm_id": 202
      }
    }
  },
  "terraform": {
    "cloud": {
      "organization": "jagadam97",
      "workspaces": {
        "name": "donnager"
      }
    },
    "required_providers": {
      "proxmox": {
        "source": "bpg/proxmox",
        "version": ">= 0.50.0"
      }
    },
    "required_version": ">= 1.0.0"
  },
  "variable": {
    "proxmox_api_url": {
      "description": "Proxmox API URL",
      "sensitive": true,
      "type": "string"
    },
    "proxmox_password": {
      "description": "Proxmox password",
      "sensitive": true,
      "type": "string"
    },
    "proxmox_username": {
      "description": "Proxmox username (e.g., root@pam)",
      "sensitive": true,
      "type": "string"
    }
  }
}
